<h1>Edit Entry</h1>

<form action="/entries/<%= @entry["id"] %>" method="post">
  <input type="hidden" name="_method" value="patch">
  <div class="mb-3">
    <label for="title_input" class="form-label">Title</label>
    <input type="text" name="title" id="title_input" class="form-control" value="<%= @entry["title"] %>">
  </div>
  <div class="mb-3">
    <label for="description_input" class="form-label">Description</label>
    <input type="text" name="description" id="description_input" class="form-control" value="<%= @entry["description"] %>">
  </div>
  <div class="mb-3">
    <label for="occurred_on_input" class="form-label">Occurred On</label>
    <input type="date" name="occurred_on" id="occurred_on_input" class="form-control" value="<%= @entry["occurred_on"] %>">
  </div>
  <button class="btn btn-primary">Save</button>
</form>
